{
  "version": 2,
  "builds": [
    {
      "src": "**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/shop/?",
      "headers": {
        "Location": "https://www.footfactorypro.shop/"
      },
      "status": 301
    },
    {
      "src": "/shop/(.*)",
      "headers": {
        "Location": "https://www.footfactorypro.shop/$1"
      },
      "status": 301
    },
    {
      "src": "/football/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/basketball/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/rugby/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/handball/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/tennis/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/judo/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/volleyball/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/natation/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/athletisme/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/boxe/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/cyclisme/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/esport/?",
      "dest": "/ffp-accueil.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/(.*)\\.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        },
        {
          "key": "X-Frame-Options",
          "value": "SAMEORIGIN"
        }
      ]
    },
    {
      "source": "/(.*)\\.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    },
    {
      "source": "/(.*)\\.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=86400"
        }
      ]
    }
  ]
}